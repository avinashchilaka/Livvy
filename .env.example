# ── Copy this file to .env and fill in your values ──────
# Never share your .env file or commit it to GitHub

# Supabase (get from supabase.com → your project → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JWT (make this a long random string — any random characters work)
JWT_SECRET=make_this_a_very_long_random_string_at_least_32_chars

# Plaid (from dashboard.plaid.com → Developers → Keys)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# Splitwise (from splitwise.com → Apps → Register your application)
SPLITWISE_CONSUMER_KEY=your_splitwise_consumer_key
SPLITWISE_CONSUMER_SECRET=your_splitwise_consumer_secret

# Your app's public URL (used for OAuth callbacks)
# Local dev: http://localhost:3000
# After deploying: https://your-app-name.onrender.com
APP_URL=http://localhost:3000

# Server port (Render sets this automatically)
PORT=3000
